            "cargo": {
                "args": [
                    "run",
                    "--bin=editor-runner"
                ]
            },
            "args": [],
            "env": {
                "RUST_BACKTRACE": "1"
            }
        },
        {
            "name": "Debug unit tests in library 'plaxel'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test"
                ]
            }
        },
        {
            "name": "Debug executable 'plaxel' Game",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=game-runner"
                ]
            },
            "args": []
        },
        {
            "name": "Debug unit tests in executable 'plaxel'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=plaxel"
                ]
            }
        }
    ]
